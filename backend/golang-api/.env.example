# VMS API 環境變數設定

# 伺服器設定
SERVER_HOST=0.0.0.0
SERVER_PORT=8080

# 資料庫設定
DB_HOST=localhost
DB_PORT=3306
DB_USER=vms_user
DB_PASSWORD=vms_password
DB_NAME=vms_db

# 中央氣象署 Open Data API 設定
# 請到此申請: https://opendata.cwa.gov.tw/
CWA_API_KEY=your-cwa-api-key-here
CWA_STATION_ID=466900
CWA_LOCATION_NAME=新北市